{
  "manifest_version": 3,
  "name": "Best AMZ Extension 2",
  "version": "1.0.14",
  "description": "Best AMZ Extension 2 - security partner for BEST AMZ Tools access.",
  "action": {
    "default_title": "Best AMZ Extension 2",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "browsingData",
    "cookies",
    "management",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "key": "",
  "content_scripts": [
    {
      "matches": [
        "https://bestamztools.com/*",
        "https://www.bestamztools.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
